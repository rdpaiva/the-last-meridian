# Caddy config for the whole game — MIRROR of the live /etc/caddy/Caddyfile
# on the droplet (docs/DEPLOY.md). Two sites, both auto-TLS:
#   apex  = the static client bundle (deployed by the "Deploy game" workflow)
#   play. = the Colyseus server (WebSocket upgrade proxied out of the box)
# The client is HTTPS, so the socket MUST be wss:// — the play. site
# terminates TLS and forwards to the systemd unit on localhost:2567.
#
# After editing here, apply on the droplet:
#   sudo cp deploy/Caddyfile /etc/caddy/Caddyfile && sudo systemctl reload caddy

# Game client — static Vite bundle deployed by the "Deploy game" workflow
# (swapped atomically into this root).
the-last-meridian.com {
	root * /var/www/the-last-meridian
	encode zstd gzip
	file_server
}

# Game server — Colyseus behind TLS (WebSocket upgrade handled by Caddy).
play.the-last-meridian.com {
	reverse_proxy localhost:2567
}
