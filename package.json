{
  "name": "space-duel",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "shared",
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev -w @space-duel/client",
    "server": "npm run dev -w @space-duel/server",
    "build": "npm run build -w @space-duel/client",
    "preview": "npm run preview -w @space-duel/client",
    "typecheck": "npm run typecheck --workspaces --if-present && tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "baseline": "CAPTURE_BASELINE=1 vitest run tests/sim/smoke.test.ts"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^5.4.0",
    "vitest": "^4.1.8"
  }
}
